# Database
# Production: set DATABASE_URL (e.g. Neon connection string) and the host/port/user/pass/name vars are ignored.
# Dev: leave DATABASE_URL empty and use the host/port/... vars below to point at local Postgres.
DATABASE_URL=
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=easy
DATABASE_PASSWORD=easy
DATABASE_NAME=easyticket

# Redis
REDIS_URL=redis://localhost:6379

# S3 (MinIO)
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=easy-ticket

# Auth
JWT_SECRET=change-me-jwt-secret
JWT_REFRESH_SECRET=change-me-jwt-refresh-secret
QR_SECRET=change-me-qr-secret

# Payments (Abacate Pay)
ABACATEPAY_API_KEY=
ABACATEPAY_WEBHOOK_SECRET=

# Email (Resend)
RESEND_API_KEY=
EMAIL_FROM=Easy Ticket <onboarding@resend.dev>
EMAIL_REPLY_TO=

# URLs
APP_URL=http://localhost:3000
API_URL=http://localhost:3001
WEB_BASE_URL=http://localhost:3000

# CORS — comma-separated list of allowed origins (overrides APP_URL when set).
# In prod, set this to your Vercel URL + custom domain, e.g.:
# CORS_ORIGINS=https://easy-ticket-web.vercel.app,https://app.seudominio.com
CORS_ORIGINS=
